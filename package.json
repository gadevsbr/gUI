{
  "name": "@bragamateus/gui",
  "version": "1.2.1",
  "description": "Minimal performance-first UI runtime with fine-grained reactivity and direct DOM bindings.",
  "license": "MIT",
  "author": "Mateus Braga",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gadevsbr/gUI.git"
  },
  "type": "module",
  "keywords": [
    "gui",
    "ui",
    "framework",
    "reactivity",
    "signals",
    "fine-grained",
    "dom",
    "frontend"
  ],
  "sideEffects": false,
  "files": [
    "gui/index.js",
    "gui/index.d.ts",
    "gui/compiler/",
    "gui/composition/",
    "gui/devtools/",
    "gui/core/",
    "gui/reactivity/",
    "gui/rendering/",
    "gui/utils/",
    "README.md",
    "LICENSE"
  ],
  "main": "./gui/index.js",
  "module": "./gui/index.js",
  "types": "./gui/index.d.ts",
  "exports": {
    ".": {
      "types": "./gui/index.d.ts",
      "import": "./gui/index.js",
      "default": "./gui/index.js"
    },
    "./compiler": {
      "types": "./gui/compiler/index.d.ts",
      "import": "./gui/compiler/index.js",
      "default": "./gui/compiler/index.js"
    },
    "./devtools": {
      "types": "./gui/devtools/index.d.ts",
      "import": "./gui/devtools/index.js",
      "default": "./gui/devtools/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check": "node scripts/check-devtools.mjs && node scripts/check-compiler.mjs && node scripts/check-syntax.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "publish:github": "npm publish --registry https://npm.pkg.github.com",
    "prepublishOnly": "npm run check && npm test",
    "prepack": "node scripts/swap-readme.mjs npm",
    "postpack": "node scripts/swap-readme.mjs restore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "happy-dom": "^20.8.9",
    "vitest": "^4.1.3"
  }
}
